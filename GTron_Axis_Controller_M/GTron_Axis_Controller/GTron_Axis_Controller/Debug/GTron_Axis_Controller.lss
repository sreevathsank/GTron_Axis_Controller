bool check_passive_flash_spi(void)
{
     d2c:	b510      	push	{r4, lr}
	EXT_FLASH_SPI_init();
     d2e:	4b0a      	ldr	r3, [pc, #40]	; (d58 <check_passive_flash_spi+0x2c>)
     d30:	4798      	blx	r3
